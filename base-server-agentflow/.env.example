ENV=development

#SERVER
PORT=3000
SERVER_URL=http://localhost:3000

#Database local
# DATABASE_URL="mongodb://localhost:27017/base"
DATABASE_URL=""

#Migration
MIGRATE_MONGO_URI="mongodb://localhost:27017/base"
MIGRATE_AUTOSYNC="true"

#BCRYPT
SALT_ROUNDS="10"

#EMAIL_SERVICE
EMAIL_SERVICE_API_KEY=""

#tokens
ACCESS_TOKEN_SECRET=""
REFRESH_TOKEN_SECRET=""

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Agent: Crawler API Keys ────────────────────────────────────────────────────
# Tavily  — articles / learning intent (https://app.tavily.com)
TAVILY_API_KEY=

# Serper  — general search + news (https://serper.dev)
SERPER_API_KEY=

# Brave   — universal fallback (https://api.search.brave.com)
BRAVE_API_KEY=

# SerpAPI — legacy Google fetcher (https://serpapi.com)
SERPAPI_KEY=

# YouTube — video format (https://console.cloud.google.com)
YOUTUBE_API_KEY=

# ── Agent: Critic AI ───────────────────────────────────────────────────────────
# Gemini  — used by critic ranker (https://aistudio.google.com)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Agent: Scraper ─────────────────────────────────────────────────────────────
SCRAPER_TIMEOUT_MS=10000
SCRAPER_MAX_RETRIES=3

# ── Agent: Queue ───────────────────────────────────────────────────────────────
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=5000